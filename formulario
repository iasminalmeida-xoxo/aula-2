<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <title>Tela Cadastro de Produtos</title>
</head>
<body>
<main>
<form action="/salvar-produto" method="POST">
    <h2>Cadastro de Novo Produto</h2>
    <label for="nome">Nome do Produto:</label>
    <input type="text" id="nome" name="nome" placeholder="Ex: Monitor Gamer 24'" required>
    <label for="categoria">Categoria:</label>
    <select id="categoria" name="categoria">
        <option value="eletronicos">Eletrônicos</option>
        <option value="moveis">Móveis</option>
        <option value="perifericos">Periféricos</option>
    </select>
    <label for="preco">Preço (R$):</label>
    <input type="number" id="preco" name="preco" step="0.01" min="0" placeholder="0,00" required>
    <label for="estoque">Quantidade em Estoque:</label>
    <input type="number" id="estoque" name="estoque" min="0" required>
    <label for="data_entrada">Data de Entrada:</label>
    <input type="date" id="data_entrada" name="data_entrada">
    <label for="descricao">Descrição do Produto:</label>
    <textarea id="descricao" name="descricao" rows="4" placeholder="Detalhes técnicos, cor, material..."></textarea>
    <label for="foto">Foto do Produto:</label>
    <input type="file" id="foto" name="foto" accept="image/*">
    <div class="botoes">
        <button type="submit">Cadastrar Produto</button>
        <button type="reset" style="background-color: #ccc;">Limpar</button>
    </div>
</form>
</main>   
</body>
</html>